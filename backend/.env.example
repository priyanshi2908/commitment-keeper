HOST=127.0.0.1
PORT=8000
DEBUG=0

HERMES_COMMAND=hermes
HERMES_TIMEOUT_SECONDS=60
HERMES_SKILL_NAME=commitment-keeper

# Leave blank to use the repo-bundled schema (recommended)
COMMITMENT_SCHEMA_PATH=
# Leave blank to use ./data/commitments.db at the repo root
COMMITMENTS_DB_PATH=

ALLOWED_ORIGINS=http://localhost:3000

# Slack (Block 3)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_CHANNELS=your-channel-id
SLACK_AUTHENTICATED_USER=your-name
SLACK_SIGNING_SECRET=your-signing-secret 
BACKEND_BASE_URL=http://127.0.0.1:8000
